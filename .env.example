SERVER_PORT=8090
FRONTEND_ORIGIN=http://localhost:5174
COOKIE_SECURE=false

# Browser login client. Keycloak redirect URI:
# http://localhost:8090/login/oauth2/code/keycloak
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=bbd
KEYCLOAK_CLIENT_ID=user-admin-console
KEYCLOAK_CLIENT_SECRET=change-me

# Server-to-server Keycloak Admin REST client.
# Assign this client's service account realm-management roles such as manage-users and view-users.
KEYCLOAK_ADMIN_CLIENT_ID=user-admin-console-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me

# User service SCIM base. With the current user service, production should use MTLS.
USER_SCIM_BASE_URL=http://localhost:8080/user
USER_SCIM_AUTH_MODE=NONE
USER_SCIM_BEARER_TOKEN=
USER_SCIM_BASIC_USERNAME=
USER_SCIM_BASIC_PASSWORD=
USER_SCIM_API_KEY_HEADER=X-API-Key
USER_SCIM_API_KEY=
USER_SCIM_KEY_STORE=
USER_SCIM_KEY_STORE_PASSWORD=
USER_SCIM_KEY_STORE_TYPE=PKCS12
USER_SCIM_TRUST_STORE=
USER_SCIM_TRUST_STORE_PASSWORD=
USER_SCIM_TRUST_STORE_TYPE=PKCS12

HDP_SECURITY_ENABLED=true
HDP_ENFORCE_ADMIN_ROLE=false
HDP_REQUIRED_ADMIN_ROLE=admin
PROVISIONING_CREATE_FAILURE_COMPENSATION=DELETE
